import cv2
cap = cv2.VideoCapture(r"C:\Users\skmoh\Downloads\videos\jiohotstartelugu_c77bb4b14b9b4d0d8df6d3acabaf4d03.mp4")
speed = 30   # default normal speed delay (ms)
paused = False
while True:
    if not paused:
        ret, frame = cap.read()
        if not ret:
            break
        frame = cv2.resize(frame, (500, 300))
        cv2.imshow("Video Player", frame)
    key = cv2.waitKey(speed) & 0xFF
    if key == 27:   # ESC key
        break
    elif key == ord('n'):   # Normal speed
        speed = 30
        print("Normal Speed")
    elif key == ord('s'):   # Slow motion
        speed = 100
        print("Slow Motion")
    elif key == ord('f'):   # Fast motion
        speed = 5
        print("Fast Motion")
    elif key == ord('p'):   # Pause / Resume
        paused = not paused
        print("Paused" if paused else "Resumed")
cap.release()
cv2.destroyAllWindows()
